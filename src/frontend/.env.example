# Frontend (Next.js) — variáveis públicas começam com NEXT_PUBLIC_
# Copie para .env.local (ou outra abordagem que usar) e ajuste

# URL base da API (remova /api se sua API expõe rota raiz diferente)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=Versatus

# Ambiente
NODE_ENV=development

# Exemplo de chave pública para recursos 3rd-party
#NEXT_PUBLIC_MAP_KEY=troque_por_sua_chave
